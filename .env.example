# Vercel (frontend + API serverless) — use same-origin /api/v1 (leave NEXT_PUBLIC_API_URL empty)
# NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# Vercel Postgres / Neon — add via Vercel Storage dashboard
# DATABASE_URL=postgresql://...

# One-time DB migration on Vercel: POST /api/v1/setup/migrate with header x-setup-secret
# SETUP_SECRET=choose-a-random-string
